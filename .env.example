# ── Copy this file to .env and fill in values ──
# cp .env.example .env

# Database
DB_USER=fintrack
DB_PASS=CHOOSE_A_STRONG_PASSWORD_HERE
DB_NAME=fintrack

# JWT Secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERATE_AND_PASTE_A_64_CHAR_RANDOM_STRING_HERE

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=https://fintrack.yourdomain.com,http://localhost:3000
